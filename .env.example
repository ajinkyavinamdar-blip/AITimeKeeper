# Copy to .env and fill in values before deploying

# Required: Flask secret key (generate a strong random string)
SECRET_KEY=change_me_in_production_use_secrets_token_hex_32

# Optional: Override SQLite path (Render mounts persistent disk at /data)
DATABASE_PATH=/data/timesheet.db

# Optional: Gemini AI for auto-categorisation
GEMINI_API_KEY=
